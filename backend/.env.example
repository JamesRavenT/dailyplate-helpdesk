# Server
PORT=3001
NODE_ENV=development

# Database (Railway provides DATABASE_URL automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5433/helpdesk

# Better Auth
# In production set both URLs to your public app URL (e.g. https://your-app.up.railway.app)
BETTER_AUTH_SECRET=change-me-to-a-minimum-32-char-random-string
BETTER_AUTH_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Seed — initial admin account (created on first boot, idempotent)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# OpenAI
OPENAI_API_KEY=sk-...

# Webhook (legacy shared-secret webhook — local testing only, disabled in production)
WEBHOOK_SECRET=change-me-to-a-random-string

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=support@yourdomain.com
RESEND_INBOUND_SECRET=...

# Sentry (leave blank to disable error reporting)
SENTRY_DSN=
# Frontend Sentry DSN — passed as a build arg in the Dockerfile (optional)
VITE_SENTRY_DSN=
