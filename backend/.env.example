# Server
PORT=3001
NODE_ENV=development

# Database (overridden by docker-compose when running in container)
DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk

# Session
SESSION_SECRET=change-me-to-a-long-random-string-in-production
FRONTEND_URL=http://localhost:5173

# OpenAI
OPENAI_API_KEY=sk-...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=support@yourdomain.com
RESEND_INBOUND_SECRET=...
