{
  "name": "helpdesk-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "prisma": "bun node_modules/prisma/build/index.js",
    "prisma:generate": "bun node_modules/prisma/build/index.js generate",
    "prisma:migrate": "bun node_modules/prisma/build/index.js migrate dev",
    "prisma:seed": "bun node_modules/prisma/build/index.js db seed",
    "prisma:studio": "bun node_modules/prisma/build/index.js studio"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7",
    "ai": "^6.0.209",
    "better-auth": "^1.6.19",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.14",
    "prisma": "7",
    "typescript": "^5.7.2"
  }
}
